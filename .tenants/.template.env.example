# Copy this file to .tenants/<tenant-name>.env and keep the new file ignored by Git.
# Set tenant_enabled=true only after every required tenant value has been reviewed.
tenant_enabled=false
tenant_id=00000000000000000000000000000000
tenant_order_number=1
tenant_name=tenantdemo
tenant_display_name=Tenant Demo
tenant_azure_domain_name=tenantdemo
tenant_custom_domain_name=tenantdemo.example.com
tenant_web_url=https://www.example.com
tenant_admin_email=admin@example.com
tenant_feedback_email=feedback@example.com

tenant_knowledge_source_1_type=web_site
tenant_knowledge_source_1_url=https://www.example.com
tenant_knowledge_source_1_refresh_period=1hour
tenant_knowledge_source_1_name=%tenant_display_name%
tenant_knowledge_source_1_description=%tenant_display_name% web sitesi seed bilgi kaynağı.
tenant_knowledge_source_1_enabled=true

tenant_text_cleaner_leading_boilerplate_terms=Ana Sayfa|Hakkımızda|İletişim|Gizlilik Politikası|Kullanım Şartları
tenant_text_cleaner_exact_boilerplate_lines=ana sayfa|hakkımızda|iletişim|gizlilik politikası|kullanım şartları
tenant_text_cleaner_footer_line_prefixes=©

primary_ai_provider=ollama-cloud
secondary_ai_provider=azure-cloud
ai_provider_ollama_cloud_model=minimax-m3:cloud
ai_provider_azure_cloud_model=deepseek-v4-flash

domain_only_crawling=true
web_document_max_count=1000
web_document_max_depth=10
Sqlite__ConnectionString=Data Source=./Data/%tenant_name%/oyako.sqlite;Cache=Shared

ui_web_brand_name=%tenant_display_name%
ui_web_assistant_name=Tenant Assistant
ui_web_title=%ui_web_assistant_name%: %ui_web_brand_name% Soru-Cevap Platformu
ui_web_header_title=%ui_web_brand_name% soru-cevap platformu
ui_web_brand_logo_url=/tenants/%tenant_name%/brand-logo.svg
ui_web_assistant_welcome_message=Merhaba, ben dijital asistanınız %ui_web_assistant_name%. %ui_web_brand_name% ile ilgili merak ettiğiniz her şeyi bana sorabilirsiniz. Cevaplamak için hazırım.
ui_web_assistant_header_title=%ui_web_brand_name% hakkında öğrenmek istediğinizi sorun:
ui_web_more_menu_brand_link=%ui_web_brand_name%
ui_web_more_menu_feedback_link=Geri Bildirim Gönderin
ui_web_more_menu_help_link=Yardım
ui_web_settings_page_title=Ayarlar
ui_web_settings_header_title=%ui_web_assistant_name% çalışma ayarları
ui_web_knowledge_bank_header_title=Bilgi Bankası
ui_web_knowledge_source_header_title=Bilgi Kaynakları
ui_web_knowledge_source_header_message=%ui_web_assistant_name%, sorularınıza cevap verirken aşağıda gösterilen {sourceCount} adet bilgi kaynağını ve {documentCount} adet belgeyi kullanabilir.
ui_web_knowledge_sources_table_title=Şu kaynaklar kullanılabilir:
ui_web_knowledge_documents_table_title=Şu belgeler kullanılabilir:
