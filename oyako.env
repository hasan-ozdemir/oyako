# Oyako global, tenant-agnostic defaults.
# Keep this file free of secrets. Tenant and provider secrets stay in ignored env files or GitHub Secrets.
default_tenant_id=013dfb350ed64e324a805eae86646ddf
default_tenant_name=oyakdijital
azure_subscription=az2vs
azure_location=italynorth
awa_sku=B1
awa_runtime=DOTNETCORE:10.0
awa_linux_fx_version=DOTNETCORE|10.0
awa_scm_settle_seconds=90
awa_deploy_timeout_milliseconds=600000
awa_recreate_webapp=true
ci_dotnet_version=10.0.x
ci_node_version=24.x
release_wait_for_startup_knowledge_ready=true
release_knowledge_ready_timeout_seconds=600
release_knowledge_poll_seconds=15
release_accept_ready_with_warnings=true
release_qna_probe_enabled=false
