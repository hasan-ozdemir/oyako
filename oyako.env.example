# Deprecated root template.
#
# Tenant configuration now lives under `.tenants/<tenant-name>.env`.
# Real tenant env files are ignored by Git. Commit only:
#
# - `.tenants/oyakdijital.env.example`
# - `.tenants/generictenant.env.example`
#
# Default tenant when no script argument is provided:
#
# tenant_name=oyakdijital
#
# Local provider secrets still stay in ignored root files:
#
# - `azure-cloud.env`
# - `ollama-cloud.env`
