# Safe deployment naming defaults. Copy to oyako.env for local overrides.
# Do not put secrets in oyako.env.

OYAKO_TENANT_SLUG=oyako

# Azure Container Apps managed host:
# https://<OYAKO_ACA_APP_NAME>.<environment-default-domain>/
# With the current managed environment this is expected to be:
# https://oyako.bluepond-a0ca5d32.italynorth.azurecontainerapps.io/
OYAKO_ACA_ENV_NAME=oyako-aca-env
OYAKO_ACA_APP_NAME=oyako
OYAKO_ACA_PREVIOUS_APP_NAME=oyako-aca
OYAKO_ACA_PREVIOUS_ENV_NAME=aca-oyako-env

# Azure App Service default host:
# https://<OYAKO_AWA_WEBAPP_NAME>.azurewebsites.net/
OYAKO_AWA_PLAN_NAME=oyako-awa-plan
OYAKO_AWA_WEBAPP_NAME=oyako
OYAKO_AWA_PREVIOUS_WEBAPP_NAME=oyako-awa-38ed446e

# Local/runtime crawling and AI defaults. These keys are aliases loaded by the API bootstrap.
domain_only_crawling=true
web_document_max_count=1000
web_document_max_depth=10
ai_default_provider=ollama-cloud
ai_fallback_provider=azure-cloud
