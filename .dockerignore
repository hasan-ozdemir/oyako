.git
.gitignore
.verification/
runtime-backups/

# Secrets and local environment files
*.env
*.env.*
!*.env.example
.tenants/*.env
!.tenants/*.env.example
!.tenants/README.md
oyako.env
azure.env
ollama.env
azure-cloud.env
ollama-cloud.env

# Logs and generated diagnostics
*.log
*.trace
playwright-report/

# Backend runtime/build artifacts
webapi-oyako/Data/
webapi-oyako/Data/**
webapi-oyako/data/
webapi-oyako/data/**
webapi-oyako/.certificates/
webapi-oyako/.certificates/**
webapi-oyako/webapi-oyako.Tests/
webapi-oyako/bin/
webapi-oyako/obj/
webapi-oyako/**/bin/
webapi-oyako/**/obj/

# Frontend dependencies/build artifacts
webapp-oyako/node_modules/
webapp-oyako/dist/
webapp-oyako/test-results/
webapp-oyako/playwright-report/

# Local deployment artifacts
.oyako-deploy/
*.zip

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/.history/
